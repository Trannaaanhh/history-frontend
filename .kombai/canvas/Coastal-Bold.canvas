 class=\"fa-solid fa-bullseye text-amber-600 text-lg\" data-kid=\"124\"></i>\n                                    </div>\n                                    <div data-kid=\"125\">\n                                        <p class=\"text-[10px] text-slate-400 font-bold uppercase tracking-widest mb-1\" data-kid=\"126\">Mục tiêu bài học</p>\n                                        <ul class=\"text-sm text-slate-600 space-y-2 list-disc pl-4\" data-kid=\"127\">\n                                            <li data-kid=\"128\">Hiểu rõ bối cảnh lịch sử cuối TK XIII.</li>\n                                            <li data-kid=\"129\">Phân tích nghệ thuật quân sự dùng cọc gỗ.</li>\n                                            <li data-kid=\"130\">Vai trò của Trần Hưng Đạo.</li>\n                                        </ul>\n                                    </div>\n                                </div>\n\n                                <div class=\"pt-6 border-t border-slate-50\" data-kid=\"131\">\n                                    <div class=\"flex items-center justify-between mb-4\" data-kid=\"132\">\n                                        <p class=\"text-[10px] text-slate-400 font-bold uppercase tracking-widest\" data-kid=\"133\">Tiến độ của bạn</p>\n                                        <span class=\"text-xs font-bold text-red-600\" data-kid=\"134\">35%</span>\n                                    </div>\n                                    <div class=\"w-full h-2.5 bg-slate-100 rounded-full overflow-hidden\" data-kid=\"135\">\n                                        <div class=\"bg-red-600 h-full rounded-full w-[35%]\" id=\"progress-bar\" data-kid=\"136\"></div>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n\n                        <div class=\"pt-8 mt-auto\" data-kid=\"137\">\n                            <button class=\"w-full bg-[#DC2626] hover:bg-red-700 py-4 rounded-2xl text-white font-bold text-lg shadow-xl shadow-red-200/40 hover:shadow-2xl hover:shadow-red-200/50 hover:scale-[1.01] transition-all transform active:scale-95\" data-kid=\"138\">\n                                Bắt đầu Quiz\n                            </button>\n                            <p class=\"text-center text-[10px] text-slate-400 mt-4 font-medium\" data-kid=\"139\">\n                                <i class=\"fa-solid fa-circle-check text-green-500 mr-1\" data-kid=\"140\"></i>\n                                Hoàn thành bài học để mở khóa huy hiệu mới\n                            </p>\n                        </div>\n\n                    </div>\n                </div>\n            </aside>\n        </div>\n    </main>\n\n    \n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"141\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"142\"></script>\n    <script data-kid=\"143\">\n        gsap.registerPlugin(ScrollTrigger);\n\n        document.addEventListener('DOMContentLoaded', () => {\n            // Entrance animation for header and title\n            gsap.from('.entrance-animate', {\n                y: 30,\n                opacity: 0,\n                duration: 1,\n                ease: 'power3.out'\n            });\n\n            // Entrance animation for cards\n            gsap.from('.lesson-card', {\n                y: 30,\n                opacity: 0,\n                duration: 0.8,\n                stagger: 0.1,\n                ease: 'power3.out',\n                scrollTrigger: {\n                    trigger: '#lesson-grid',\n                    start: 'top 85%'\n                }\n            });\n\n            // Entrance animation for sidebar\n            gsap.from('aside', {\n                x: 40,\n                opacity: 0,\n                duration: 1,\n                delay: 0.4,\n                ease: 'power3.out'\n            });\n\n            // Animate progress bar\n            gsap.from('#progress-bar', {\n                width: 0,\n                duration: 1.5,\n                delay: 1,\n                ease: 'power2.inOut'\n            });\n\n            // Filter button logic (simulated)\n            const filterBtns = document.querySelectorAll('.filter-btn');\n            filterBtns.forEach(btn => {\n                btn.addEventListener('click', () => {\n                    filterBtns.forEach(b => b.classList.remove('filter-btn-active', 'text-slate-500'));\n                    filterBtns.forEach(b => b.classList.add('text-slate-500'));\n                    btn.classList.add('filter-btn-active');\n                    btn.classList.remove('text-slate-500');\n                    \n                    // Small click feedback\n                    gsap.fromTo(btn, {scale: 0.96}, {scale: 1, duration: 0.4, ease: 'back.out(2)'});\n                });\n            });\n        });\n    </script>\n</div>\n",
