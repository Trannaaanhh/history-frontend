ransition-transform\" data-kid=\"98\"></i>\n                            </button>\n                        </div>\n                    </div>\n\n                </div>\n                \n                <div class=\"mt-16 text-center entrance-animate\" data-kid=\"99\">\n                    <button class=\"px-10 py-4 rounded-2xl border border-slate-200 text-slate-500 font-bold text-sm hover:border-[#DC2626] hover:text-[#DC2626] hover:bg-red-50/30 transition-all hover:shadow-sm inline-flex items-center gap-3 group\" data-kid=\"100\">\n                        Xem thêm bài học\n                        <i class=\"fa-solid fa-chevron-down text-[10px] group-hover:translate-y-1 transition-transform\" data-kid=\"101\"></i>\n                    </button>\n                </div>\n            </div>\n\n            \n            <aside class=\"lg:col-span-4\" data-kid=\"102\">\n                <div class=\"sidebar-sticky\" data-kid=\"103\">\n                    <div class=\"bg-white rounded-3xl border border-slate-100 card-shadow p-8 flex flex-col h-full overflow-hidden\" data-kid=\"104\">\n                        \n                        <div class=\"flex items-center gap-3 mb-8\" data-kid=\"105\">\n                            <div class=\"w-2 h-8 bg-red-600 rounded-full\" data-kid=\"106\"></div>\n                            <h3 class=\"text-2xl font-bold text-slate-800 font-['Playfair_Display',serif]\" data-kid=\"107\">Chi tiết bài học</h3>\n                        </div>\n\n                        <div class=\"flex-grow space-y-8 overflow-y-auto pr-2 custom-scrollbar\" data-kid=\"108\">\n                            \n                            <div class=\"relative group rounded-2xl overflow-hidden aspect-video mb-6 border border-slate-100\" data-kid=\"109\">\n                                <img src=\"https://kombai-assets.b-cdn.net/generated_assets/23ef1097-47db-4cfb-b45f-423ef4fa11bd/57a1a248bdf545328e715502919bec0e.jpg\" alt=\"Active\" class=\"w-full h-full object-cover