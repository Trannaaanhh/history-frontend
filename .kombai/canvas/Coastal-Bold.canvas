      "html": "\n<div class=\"min-h-screen bg-slate-50 font-sans text-slate-900 selection:bg-red-100 selection:text-red-700\" data-kid=\"0\">\n  \n  <style data-kid=\"1\">\n    @import url('https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@300;400;500;600;700;800&display=swap');\n    \n    .font-serif { font-family: 'Crimson Pro', serif; }\n    .font-sans { font-family: 'Inter', sans-serif; }\n\n    /* Custom Scrollbar for AI Chat */\n    .chat-scroll::-webkit-scrollbar { width: 5px; }\n    .chat-scroll::-webkit-scrollbar-track { background: transparent; }\n    .chat-scroll::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 10px; }\n    .chat-scroll::-webkit-scrollbar-thumb:hover { background: #cbd5e1; }\n\n    .stroke-round { stroke-linecap: round; }\n    /* Hide scrollbar but keep functionality */\n    .no-scrollbar::-webkit-scrollbar { display: none; }\n    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }\n  </style>\n  <script src=\"https://unpkg.com/@phosphor-icons/web\" data-kid=\"2\"></script>\n  <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"3\"></script>\n  <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"4\"></script>\n\n  \n  <aside class=\"fixed left-0 top-0 h-screen w-20 xl:w-72 bg-white border-r border-slate-100 z-50 flex flex-col items-center xl:items-stretch py-8 transition-all\" data-kid=\"5\">\n    <div class=\"px-8 mb-12 flex items-center gap-4\" data-kid=\"6\">\n      <div class=\"w-12 h-12 bg-red-600 rounded-2xl flex items-center justify-center shrink-0 shadow-xl shadow-red-100\" data-kid=\"7\">\n        <i class=\"ph-fill ph-scroll text-white text-2xl\" data-kid=\"8\"></i>\n      </div>\n      <div class=\"hidden xl:block\" data-kid=\"9\">\n        <span class=\"font-serif text-xl font-black text-red-800 leading-tight tracking-tight\" data-kid=\"10\">LỊCH SỬ VIỆT</span>\n        <p class=\"text-[11px] font-black text-slate-400 uppercase tracking-[0.15em] mt-0.5\" data-kid=\"11\">Nền tảng học tập</p>\n      </div>\n    </div>\n\n    <nav class=\"flex-1 px-4 space-y-1.5 pt-2\" data-kid=\"12\">\n      <a href=\"#\" class=\"group flex items-center gap-4 px-5 py-3.5 rounded-2xl bg-red-600 text-white font-bold transition-all shadow-lg shadow-red-100 relative\" data-kid=\"13\">\n        <i class=\"ph-fill ph-grid-four text-2xl\" data-kid=\"14\"></i>\n        <span class=\"hidden xl:block\" data-kid=\"15\">Trang tổng quan</span>\n      </a>\n      <a href=\"#\" class=\"group flex items-center gap-4 px-5 py-3.5 rounded-2xl text-slate-500 hover:bg-slate-50 hover:text-slate-800 transition-all\" data-kid=\"16\">\n        <i class=\"ph-bold ph-book-open-text text-2xl\" data-kid=\"17\"></i>\n        <span class=\"hidden xl:block\" data-kid=\"18\">Bài học tương tác</span>\n      </a>\n      <a href=\"#\" class=\"group flex items-center gap-4 px-5 py-3.5 rounded-2xl text-slate-400 hover:bg-slate-50 hover:text-slate-600 transition-all\" data-kid=\"19\">\n        <i class=\"ph-bold ph-chart-bar text-2xl\" data-kid=\"20\"></i>\n        <span class=\"hidden xl:block\" data-kid=\"21\">Tiến độ học tập</span>\n      </a>\n      <a href=\"#\" class=\"group flex items-center gap-4 px-5 py-3.5 rounded-2xl text-slate-400 hover:bg-slate-50 hover:text-slate-600 transition-all\" data-kid=\"22\">\n        <i class=\"ph-bold ph-trophy text-2xl\" data-kid=\"23\"></i>\n        <span class=\"hidden xl:block\" data-kid=\"24\">Bảng thành tích</span>\n      </a>\n      <a href=\"#\" class=\"group flex items-center gap-4 px-5 py-3.5 rounded-2xl text-slate-400 hover:bg-slate-50 hover:text-slate-600 transition-all\" data-kid=\"25\">\n        <i class=\"ph-bold ph-sparkle text-2xl\" data-kid=\"26\"></i>\n        <span class=\"hidden xl:block\" data-kid=\"27\">Trợ lý AI Sử Việt</span>\n      </a>\n    </nav>\n\n    <div class=\"px-6 mt-auto\" data-kid=\"28\">\n      <div class=\"xl:bg-slate-50/50 border border-slate-100 rounded-3xl p-4 flex items-center gap-4 hover:border-red-100 transition-colors\" data-kid=\"29\">\n        <img src=\"https://i.pravatar.cc/100?u=tran\" alt=\"User\" class=\"w-11 h-11 rounded-xl border-2 border-white shadow-sm shrink-0\" decoding=\"async\" loading=\"lazy\" data-kid=\"30\">\n        <div class=\"hidden xl:block overflow-hidden\" data-kid=\"31\">\n          <p class=\"text-sm font-bold text-slate-800 truncate\" data-kid=\"32\">Trần Quang Minh</p>\n          <div class=\"flex items-center gap-1.5 mt-0.5\" data-kid=\"33\">\n            <span class=\"w-1.5 h-1.5 bg-amber-500 rounded-full shadow-[0_0_8px_rgba(245,158,11,0.5)]\" data-kid=\"34\"></span>\n            <p class=\"text-[11px] text-slate-500 font-black uppercase tracking-widest\" data-kid=\"35\">Hạng Vàng</p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </aside>\n\n  \n  <main class=\"pl-20 xl:pl-64 pt-6 min-h-screen\" data-kid=\"36\">\n    <div class=\"max-w-7xl mx-auto px-6 pb-12\" data-kid=\"37\">\n      \n      \n      <div class=\"flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4\" data-kid=\"38\">\n        <div class=\"flex items-center gap-4\" data-kid=\"39\">\n          <div class=\"w-14 h-14 rounded-2xl bg-white border border-slate-100 shadow-sm flex items-center justify-center p-1\" data-kid=\"40\">\n            <img src=\"https://i.pravatar.cc/100?u=tran\" alt=\"User\" class=\"w-full h-full rounded-xl object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"41\">\n          </div>\n          <div data-kid=\"42\">\n            <h1 class=\"text-2xl xl:text-3xl font-serif font-bold text-slate-800\" data-kid=\"43\">Chào buổi sáng, Minh!</h1>\n            <p class=\"text-slate-500 font-medium text-sm\" data-kid=\"44\">Hãy tiếp tục hành trình khám phá lịch sử Đại Việt.</p>\n          </div>\n        </div>\n        <div class=\"flex items-center gap-4 w-full md:w-auto\" data-kid=\"45\">\n          <div class=\"flex-1 md:flex-none bg-white px-5 py-3 rounded-2xl border border-slate-100 flex items-center gap-4 shadow-sm group hover:border-red-200 transition-all\" data-kid=\"46\">\n            <div class=\"w-10 h-10 rounded-xl bg-red-50 flex items-center justify-center text-red-600 group-hover:scale-110 transition-transform\" data-kid=\"47\">\n              <i class=\"ph-fill ph-fire text-xl\" data-kid=\"48\"></i>\n            </div>\n            <div data-kid=\"49\">\n              <p class=\"text-[11px] text-slate-400 font-black tracking-widest leading-none mb-1\" data-kid=\"50\">STREAK</p>\n              <p class=\"text-base font-black text-slate-800\" data-kid=\"51\">12 Ngày</p>\n            </div>\n          </div>\n          <button class=\"w-12 h-12 rounded-2xl bg-white border border-slate-100 flex items-center justify-center text-slate-400 hover:text-red-600 transition-all shadow-sm relative\" data-kid=\"52\">\n            <i class=\"ph-bold ph-bell-ringing text-xl\" data-kid=\"53\"></i>\n            <span class=\"absolute top-3 right-3 w-2.5 h-2.5 bg-red-600 border-2 border-white rounded-full\" data-kid=\"54\"></span>\n          </button>\n        </div>\n      </div>\n\n      \n      <div class=\"grid grid-cols-12 gap-8\" data-kid=\"55\">\n        \n        \n        <div class=\"col-span-12 lg:col-span-8 space-y-8\" data-kid=\"56\">\n          \n          \n          <div class=\"grid grid-cols-1 xl:grid-cols-2 gap-8\" data-kid=\"57\">\n            \n            <div class=\"space-y-8\" data-kid=\"58\">\n              \n              <div class=\"bg-white p-6 rounded-[2.5rem] shadow-sm border border-slate-100 flex items-center gap-6 group hover:shadow-md transition-shadow\" data-kid=\"59\">\n                <div class=\"relative w-24 h-24 shrink-0\" data-kid=\"60\">\n                  <svg class=\"w-full h-full transform -rotate-90\" data-kid=\"61\">\n                    <circle cx=\"48\" cy=\"48\" r=\"42\" stroke=\"currentColor\" stroke-width=\"8\" fill=\"transparent\" class=\"text-slate-50\" data-kid=\"62\"></circle>\n                    <circle cx=\"48\" cy=\"48\" r=\"42\" stroke=\"currentColor\" stroke-width=\"8\" fill=\"transparent\" stroke-dasharray=\"263.89\" stroke-dashoffset=\"65.97\" class=\"text-red-600 stroke-round\" data-kid=\"63\"></circle>\n                  </svg>\n                  <div class=\"absolute inset-0 flex flex-col items-center justify-center\" data-kid=\"64\">\n                    <span class=\"text-3xl font-black text-slate-800 tracking-tighter\" data-kid=\"65\">75%</span>\n                  </div>\n                </div>\n                <div class=\"flex-1\" data-kid=\"66\">\n                  <h3 class=\"text-slate-400 text-xs font-black uppercase tracking-[0.1em] mb-1\" data-kid=\"67\">Tiến độ khóa học</h3>\n                  <p class=\"text-base font-bold text-slate-800 leading-tight mb-2\" data-kid=\"68\">Đại Việt thời Trần (1225 - 1400)</p>\n                  <div class=\"w-full bg-slate-50 h-1.5 rounded-full overflow-hidden mt-3\" data-kid=\"69\">\n                    <div class=\"bg-red-600 h-full rounded-full\" style=\"width: 75%\" data-kid=\"70\"></div>\n                  </div>\n                </div>\n              </div>\n\n              \n              <div class=\"bg-white p-6 rounded-[2.5rem] shadow-sm border border-slate-100\" data-kid=\"71\">\n                <div class=\"flex justify-between items-center mb-5 px-1\" data-kid=\"72\">\n                  <h3 class=\"text-slate-400 text-xs font-black uppercase tracking-[0.1em]\" data-kid=\"73\">Huy chương đạt được</h3>\n                  <span class=\"text-amber-600 text-xs font-black\" data-kid=\"74\">2/10</span>\n                </div>\n                <div class=\"flex justify-between items-center px-2\" data-kid=\"75\">\n                  <div class=\"flex flex-col items-center gap-2 group cursor-pointer\" data-kid=\"76\">\n                    <div class=\"w-14 h-14 rounded-2xl bg-amber-50 border border-amber-100 flex items-center justify-center shadow-sm group-hover:scale-110 group-hover:border-amber-400 group-hover:shadow-amber-100 transition-all\" data-kid=\"77\">\n                      <i class=\"ph-fill ph-scroll text-2xl text-amber-600\" data-kid=\"78\"></i>\n                    </div>\n                    <span class=\"text-[11px] font-bold text-slate-500 text-center\" data-kid=\"79\">Nhà Sử Học</span>\n                  </div>\n                  <div class=\"flex flex-col items-center gap-2 group cursor-pointer\" data-kid=\"80\">\n                    <div class=\"w-14 h-14 rounded-2xl bg-red-50 border border-red-100 flex items-center justify-center shadow-sm group-hover:scale-110 group-hover:border-red-400 group-hover:shadow-red-100 transition-all\" data-kid=\"81\">\n                      <i class=\"ph-fill ph-student text-2xl text-red-600\" data-kid=\"82\"></i>\n                    </div>\n                    <span class=\"text-[11px] font-bold text-slate-500 text-center\" data-kid=\"83\">Học Sinh Giỏi</span>\n                  </div>\n                  <div class=\"flex flex-col items-center gap-2 opacity-40 grayscale group hover:opacity-100 transition-all\" data-kid=\"84\">\n                    <div class=\"w-14 h-14 rounded-2xl bg-slate-50 border border-slate-100 flex items-center justify-center\" data-kid=\"85\">\n                      <i class=\"ph-fill ph-crown text-2xl text-slate-400\" data-kid=\"86\"></i>\n                    </div>\n                    <span class=\"text-[11px] font-bold text-slate-400 text-center\" data-kid=\"87\">Hoàng Đế</span>\n                  </div>\n                  <div class=\"flex flex-col items-center gap-2 opacity-40 grayscale group hover:opacity-100 transition-all\" data-kid=\"88\">\n                    <div class=\"w-14 h-14 rounded-2xl bg-slate-50 border border-slate-100 flex items-center justify-center\" data-kid=\"89\">\n                      <i class=\"ph-fill ph-sword text-2xl text-slate-400\" data-kid=\"90\"></i>\n                    </div>\n                    <span class=\"text-[11px] font-bold text-slate-400 text-center\" data-kid=\"91\">Tướng Quân</span>\n                  </div>\n                </div>\n              </div>\n            </div>\n\n            \n            <div class=\"bg-white p-8 rounded-[2.5rem] shadow-sm border border-slate-100 flex flex-col\" data-kid=\"92\">\n              <div class=\"flex justify-between items-start mb-8\" data-kid=\"93\">\n                <div data-kid=\"94\">\n                  <h3 class=\"text-slate-400 text-xs font-black uppercase tracking-[0.1em] mb-2\" data-kid=\"95\">Điểm số quan trọng</h3>\n                  <div class=\"flex items-baseline gap-2\" data-kid=\"96\">\n                    <span class=\"text-4xl font-black text-slate-800 tracking-tighter\" data-kid=\"97\">8.5</span>\n                    <span class=\"text-slate-400 font-bold text-sm\" data-kid=\"98\">/ 10.0</span>\n                  </div>\n                </div>\n                <div class=\"flex items-center gap-2 bg-slate-50 p-1 rounded-xl border border-slate-100\" data-kid=\"99\">\n                  <button class=\"px-3 py-1.5 bg-white shadow-sm rounded-lg text-xs font-black text-red-600 uppercase tracking-wider\" data-kid=\"100\">Tuần</button>\n                  <button class=\"px-3 py-1.5 text-xs font-black text-slate-400 uppercase tracking-wider\" data-kid=\"101\">Tháng</button>\n                </div>\n              </div>\n              \n              <div class=\"flex-1 flex items-end justify-between gap-4 px-1 min-h-[140px]\" data-kid=\"102\">\n                <div class=\"flex-1 flex flex-col items-center gap-3 group\" data-kid=\"103\">\n                  <div class=\"relative w-full bg-slate-50 rounded-xl h-28 overflow-hidden border border-slate-100\" data-kid=\"104\">\n                    <div class=\"absolute bottom-0 left-0 w-full bg-red-600 rounded-t-xl chart-bar-anim h-[45%]\" data-kid=\"105\"></div>\n                  </div>\n                  <span class=\"text-[11px] font-black text-slate-400 uppercase tracking-widest\" data-kid=\"106\">Th 9</span>\n                </div>\n                <div class=\"flex-1 flex flex-col items-center gap-3 group\" data-kid=\"107\">\n                  <div class=\"relative w-full bg-slate-50 rounded-xl h-28 overflow-hidden border border-slate-100\" data-kid=\"108\">\n                    <div class=\"absolute bottom-0 left-0 w-full bg-red-600 rounded-t-xl chart-bar-anim h-[65%]\" data-kid=\"109\"></div>\n                  </div>\n                  <span class=\"text-[11px] font-black text-slate-400 uppercase tracking-widest\" data-kid=\"110\">Th 10</span>\n                </div>\n                <div class=\"flex-1 flex flex-col items-center gap-3 group\" data-kid=\"111\">\n                  <div class=\"relative w-full bg-slate-50 rounded-xl h-28 overflow-hidden border border-slate-100\" data-kid=\"112\">\n                    <div class=\"absolute bottom-0 left-0 w-full bg-red-600 rounded-t-xl chart-bar-anim h-[82%]\" data-kid=\"113\"></div>\n                  </div>\n                  <span class=\"text-[11px] font-black text-slate-400 uppercase tracking-widest\" data-kid=\"114\">Th 11</span>\n                </div>\n                <div class=\"flex-1 flex flex-col items-center gap-3 group\" data-kid=\"115\">\n                  <div class=\"relative w-full bg-slate-50 rounded-xl h-28 overflow-hidden ring-4 ring-amber-400/10 border border-amber-200\" data-kid=\"116\">\n                    <div class=\"absolute bottom-0 left-0 w-full bg-red-600 rounded-t-xl chart-bar-anim h-[90%]\" data-kid=\"117\"></div>\n                  </div>\n                  <span class=\"text-[11px] font-black text-red-600 uppercase tracking-widest\" data-kid=\"118\">Hiện tại</span>\n                </div>\n              </div>\n            </div>\n          </div>\n\n          \n          <div class=\"bg-white rounded-[2.5rem] p-10 shadow-xl shadow-slate-200/40 border border-slate-100 relative overflow-hidden quiz-card\" data-kid=\"119\">\n            \n            <div class=\"absolute top-0 left-0 w-full h-2.5 bg-slate-50\" data-kid=\"120\">\n              <div class=\"h-full bg-red-600 transition-all duration-1000\" style=\"width: 16.6%\" data-kid=\"121\"></div>\n            </div>\n            \n            <div class=\"flex justify-between items-center mb-10 pt-2\" data-kid=\"122\">\n              <span class=\"text-slate-400 font-bold uppercase tracking-[0.2em] text-xs\" data-kid=\"123\">CÂU HỎI 2 / 12</span>\n              <div class=\"flex items-center gap-3 px-4 py-2 bg-amber-50 rounded-2xl border border-amber-100\" data-kid=\"124\">\n                <i class=\"ph-bold ph-timer text-amber-600 text-lg\" data-kid=\"125\"></i>\n                <span class=\"text-amber-700 font-black tabular-nums\" data-kid=\"126\">00:45</span>\n              </div>\n            </div>\n\n            <h2 class=\"text-3xl font-serif text-slate-800 font-bold leading-[1.3] mb-12\" data-kid=\"127\">\n              Vị tướng nào đã lãnh đạo quân đội nhà Trần đánh bại quân Nguyên Mông trong trận Bạch Đằng năm 1288?\n            </h2>\n\n            <div class=\"grid grid-cols-1 md:grid-cols-2 gap-5\" data-kid=\"128\">\n              \n              <button class=\"group relative flex items-center gap-5 p-6 rounded-3xl border-2 border-slate-100 bg-white hover:border-amber-400 hover:shadow-lg hover:shadow-amber-50 transition-all text-left\" data-kid=\"129\">\n                <span class=\"flex items-center justify-center w-12 h-12 rounded-2xl bg-slate-50 text-slate-400 font-bold text-lg group-hover:bg-amber-100 group-hover:text-amber-600 transition-colors\" data-kid=\"130\">A</span>\n                <span class=\"text-slate-700 font-semibold text-lg\" data-kid=\"131\">Trần Thủ Độ</span>\n              </button>\n\n              \n              <button class=\"group relative flex items-center gap-5 p-6 rounded-3xl border-2 border-emerald-500 bg-emerald-50 text-left shadow-lg shadow-emerald-100 transition-all\" data-kid=\"132\">\n                <span class=\"flex items-center justify-center w-12 h-12 rounded-2xl bg-emerald-500 text-white font-bold text-lg shadow-lg shadow-emerald-200\" data-kid=\"133\">B</span>\n                <span class=\"text-emerald-900 font-bold text-lg\" data-kid=\"134\">Trần Hưng Đạo</span>\n                <div class=\"ml-auto w-8 h-8 rounded-full bg-emerald-500 text-white flex items-center justify-center shadow-md\" data-kid=\"135\">\n                   <i class=\"ph-bold ph-check text-xl\" data-kid=\"136\"></i>\n                </div>\n              </button>\n\n              \n              <button class=\"group relative flex items-center gap-5 p-6 rounded-3xl border-2 border-red-500 bg-red-50 text-left shadow-lg shadow-red-100 transition-all\" data-kid=\"137\">\n                <span class=\"flex items-center justify-center w-12 h-12 rounded-2xl bg-red-500 text-white font-bold text-lg shadow-lg shadow-red-200\" data-kid=\"138\">C</span>\n                <span class=\"text-red-900 font-bold text-lg\" data-kid=\"139\">Trần Quang Khải</span>\n                <div class=\"ml-auto w-8 h-8 rounded-full bg-red-500 text-white flex items-center justify-center shadow-md\" data-kid=\"140\">\n                   <i class=\"ph-bold ph-x text-xl\" data-kid=\"141\"></i>\n                </div>\n              </button>\n\n              \n              <button class=\"group relative flex items-center gap-5 p-6 rounded-3xl border-2 border-slate-100 bg-white hover:border-amber-400 hover:shadow-lg hover:shadow-amber-50 transition-all text-left\" data-kid=\"142\">\n                <span class=\"flex items-center justify-center w-12 h-12 rounded-2xl bg-slate-50 text-slate-400 font-bold text-lg group-hover:bg-amber-100 group-hover:text-amber-600 transition-colors\" data-kid=\"143\">D</span>\n                <span class=\"text-slate-700 font-semibold text-lg\" data-kid=\"144\">Trần Nhật Duật</span>\n              </button>\n            </div>\n\n            <div class=\"mt-12 pt-8 border-t border-slate-100 flex justify-between items-center\" data-kid=\"145\">\n              <button class=\"text-slate-400 text-sm font-bold hover:text-red-500 transition-all flex items-center gap-2 group\" data-kid=\"146\">\n                <i class=\"ph-bold ph-info group-hover:animate-pulse\" data-kid=\"147\"></i> Báo cáo lỗi\n              </button>\n              <button class=\"px-12 py-4 bg-red-600 hover:bg-red-700 text-white font-bold rounded-2xl shadow-xl shadow-red-200 transition-all flex items-center gap-3 scale-100 hover:scale-105 active:scale-95\" data-kid=\"148\">\n                Câu tiếp theo <i class=\"ph-bold ph-arrow-right group-hover:translate-x-1 transition-transform\" data-kid=\"149\"></i>\n              </button>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"col-span-12 lg:col-span-4 space-y-8\" data-kid=\"150\">\n          \n          \n          <div class=\"bg-white rounded-[2.5rem] shadow-xl shadow-slate-200/50 border border-slate-100 flex flex-col overflow-hidden h-auto max-h-[850px] lg:sticky lg:top-6\" data-kid=\"151\">\n            \n            <div class=\"p-8 border-b border-slate-100 flex items-center justify-between\" data-kid=\"152\">\n              <div class=\"flex items-center gap-4\" data-kid=\"153\">\n                <div class=\"w-12 h-12 rounded-2xl bg-gradient-to-br from-amber-400 to-amber-600 flex items-center justify-center text-white shadow-lg shadow-amber-200\" data-kid=\"154\">\n                  <i class=\"ph-fill ph-sparkle text-2xl\" data-kid=\"155\"></i>\n                </div>\n                <div data-kid=\"156\">\n                  <h3 class=\"font-bold text-slate-800 text-lg leading-tight\" data-kid=\"157\">Trợ lý Sử Việt</h3>\n                  <div class=\"flex items-center gap-1.5\" data-kid=\"158\">\n                    <span class=\"w-2 h-2 rounded-full bg-emerald-500 animate-pulse\" data-kid=\"159\"></span>\n                    <span class=\"text-emerald-600 text-[11px] font-bold uppercase tracking-wider\" data-kid=\"160\">Trực tuyến</span>\n                  </div>\n                </div>\n              </div>\n              <button class=\"w-10 h-10 rounded-xl bg-slate-50 text-slate-400 flex items-center justify-center hover:bg-slate-100 hover:text-slate-600 transition-all\" data-kid=\"161\">\n                <i class=\"ph-bold ph-dots-three-vertical text-xl\" data-kid=\"162\"></i>\n              </button>\n            </div>\n\n            \n            <div class=\"flex-1 overflow-y-auto p-8 space-y-8 chat-scroll\" data-kid=\"163\">\n              \n              <div class=\"flex flex-col items-start gap-3 max-w-[90%] group\" data-kid=\"164\">\n                <div class=\"bg-amber-50/30 text-slate-700 p-5 rounded-3xl rounded-tl-none border border-amber-100 text-[15px] leading-relaxed shadow-sm\" data-kid=\"165\">\n                  Chào Minh! Tôi là trợ lý AI chuyên về Lịch sử Việt Nam. Bạn có thắc mắc gì về các trận đánh thời nhà Trần không?\n                </div>\n                <span class=\"text-[10px] text-slate-300 font-bold ml-1\" data-kid=\"166\">Vừa xong</span>\n              </div>\n\n              \n              <div class=\"flex flex-col items-end gap-3 ml-auto max-w-[90%] group\" data-kid=\"167\">\n                <div class=\"bg-red-600 text-white p-5 rounded-3xl rounded-tr-none text-[15px] leading-relaxed shadow-lg shadow-red-100 font-medium\" data-kid=\"168\">\n                  Hãy giải thích ý nghĩa của chiến thuật đóng cọc gỗ của Hưng Đạo Vương?\n                </div>\n                <span class=\"text-[10px] text-slate-300 font-bold mr-1\" data-kid=\"169\">10:42 AM</span>\n              </div>\n\n              \n              <div class=\"flex flex-col items-start gap-4 max-w-[95%]\" data-kid=\"170\">\n                <div class=\"bg-white border-2 border-amber-100 p-6 rounded-3xl rounded-tl-none shadow-md shadow-amber-50 text-[15px] leading-relaxed text-slate-800\" data-kid=\"171\">\n                  <p class=\"mb-4 font-semibold text-amber-700\" data-kid=\"172\">Đây là một nghệ thuật quân sự độc đáo:</p>\n                  <ul class=\"space-y-3 mb-6\" data-kid=\"173\">\n                    <li class=\"flex gap-3\" data-kid=\"174\">\n                      <i class=\"ph-bold ph-caret-right text-amber-500 shrink-0 mt-1\" data-kid=\"175\"></i>\n                      <span data-kid=\"176\">Lợi dụng chênh lệch thủy triều sông Bạch Đằng để vô hiệu hóa sức mạnh thuyền chiến của quân Nguyên Mông.</span>\n                    </li>\n                    <li class=\"flex gap-3\" data-kid=\"177\">\n                      <i class=\"ph-bold ph-caret-right text-amber-500 shrink-0 mt-1\" data-kid=\"178\"></i>\n                      <span data-kid=\"179\">Kết hợp bãi cọc ngầm với các đạo quân mai phục hai bên bờ để bao vây tiêu diệt địch khi chúng mắc cạn.</span>\n                    </li>\n                  </ul>\n                  \n                  \n                  <div class=\"pt-5 border-t border-slate-100\" data-kid=\"180\">\n                    <div class=\"flex items-center gap-2 mb-3\" data-kid=\"181\">\n                      <i class=\"ph-fill ph-books text-amber-600\" data-kid=\"182\"></i>\n                      <span class=\"text-[10px] text-slate-400 font-black uppercase tracking-widest\" data-kid=\"183\">Nguồn tham khảo</span>\n                    </div>\n                    <div class=\"flex flex-wrap gap-2\" data-kid=\"184\">\n                      <span class=\"px-3 py-1.5 bg-amber-50 text-amber-700 text-xs rounded-xl font-bold border border-amber-100 hover:bg-amber-100 cursor-default transition-colors\" data-kid=\"185\">\n                        Đại Việt Sử Ký Toàn Thư\n                      </span>\n                      <span class=\"px-3 py-1.5 bg-amber-50 text-amber-700 text-xs rounded-xl font-bold border border-amber-100 hover:bg-amber-100 cursor-default transition-colors\" data-kid=\"186\">\n       