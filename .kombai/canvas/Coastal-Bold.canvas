\"async\" loading=\"lazy\" data-kid=\"107\">\n        </div>\n      </div>\n\n      \n      <div class=\"lg:col-span-5 flex flex-col gap-8\" data-kid=\"108\">\n        \n        <div class=\"case-card flex-grow bg-red-50 border border-red-100 rounded-3xl overflow-hidden flex flex-col opacity-0 translate-y-12\" data-kid=\"109\">\n          <div class=\"relative h-48 sm:h-64 overflow-hidden\" data-kid=\"110\">\n             <img src=\"https://kombai-assets.b-cdn.net/generated_assets/23ef1097-47db-4cfb-b45f-423ef4fa11bd/8691fc5b7fbe4a5ba49ebb6e38d227c3.jpg?auto=compress&cs=tinysrgb&w=800&q=80\" alt=\"Interact\" class=\"w-full h-full object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"111\">\n          </div>\n          <div class=\"p-10 flex-grow\" data-kid=\"112\">\n            <h3 class=\"mb-4 italic font-bold text-2xl text-red-900 font-display\" data-kid=\"113\">Bài học tương tác 3D</h3>\n            <p class=\"text-red-700/70 text-sm leading-relaxed\" data-kid=\"114\">Tái hiện các trận đánh và di tích lịch sử qua công nghệ không gian 3 chiều sinh động.</p>\n          </div>\n        </div>\n\n        \n        <div class=\"case-card flex-grow bg-amber-50 border border-amber-100 rounded-3xl overflow-hidden flex flex-col opacity-0 translate-y-12\" data-kid=\"115\">\n          <div class=\"p-10 flex-grow\" data-kid=\"116\">\n            <h3 class=\"mb-4 italic font-bold text-2xl text-amber-900 font-display\" data-kid=\"117\">Ngân hàng đề thông minh</h3>\n            <p class=\"text-amber-800/70 text-sm leading-relaxed\" data-kid=\"118\">Hệ thống đánh giá năng lực cá nhân hóa, giúp học sinh nắm vững kiến thức trọng tâm THPT.</p>\n          </div>\n          <div class=\"relative h-48 sm:h-64 overflow-hidden\" data-kid=\"119\">\n             <img src=\"https://kombai-assets.b-cdn.net/generated_assets/23ef1097-47db-4cfb-b45f-423ef4fa11bd/b582c181081142359a410d2caac06a4c.jpg?auto=compress&cs=tinysrgb&w=800&q=80\" alt=\"Test\" class=\"w-full h-full object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"120\">\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<footer id=\"lien-he\" class=\"bg-red-950 text-stone-100 py-32 px-12 overflow-hidden\" data-kid=\"121\">\n  <div class=\"flex items-center justify-center gap-6 md:gap-16 mb-16\" data-kid=\"122\">\n    <div id=\"footer-rule-l\" class=\"flex-1 h-0.5 bg-[var(--vn-red)] origin-right\" data-kid=\"123\"></div>\n    <div id=\"footer-logo\" class=\"italic font-black text-4xl md:text-7xl lg:text-8xl tracking-widest font-display text-white whitespace-nowrap\" data-kid=\"124\">LỊCH SỬ VIỆT NAM</div>\n    <div id=\"footer-rule-r\" class=\"flex-1 h-0.5 bg-[var(--vn-red)] origin-left\" data-kid=\"125\"></div>\n  </div>\n  \n  <p id=\"footer-coord\" class=\"text-center font-mono text-[10px] tracking-[0.4em] text-stone-500 mb-24 opacity-0\" data-kid=\"126\">21.0285° N · HÀ NỘI · VIỆT NAM</p>\n\n  <div class=\"max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-16 pt-16 border-t border-white/10\" data-kid=\"127\">\n    <div class=\"reveal-up opacity-0\" data-kid=\"128\">\n      <p class=\"mb-6 font-mono text-[10px] tracking-widest uppercase text-stone-500\" data-kid=\"129\">Dự án</p>\n      <p class=\"italic font-bold text-2xl text-white font-display mb-3\" data-kid=\"130\">Học Sử Việt</p>\n      <a href=\"mailto:lienhe@lichsuvn.edu\" class=\"text-amber-500 hover:text-[var(--vn-red)] transition-colors text-lg\" data-kid=\"131\">lienhe@lichsuvn.edu</a>\n    </div>\n\n    <div class=\"reveal-up opacity-0\" style=\"transition-delay: 100ms;\" data-kid=\"132\">\n      <p class=\"mb-6 font-mono text-[10px] tracking-widest uppercase text-stone-500\" data-kid=\"133\">Điều hướng</p>\n      <ul class=\"space-y-4 font-sans text-stone-400\" data-kid=\"134\">\n        <li data-kid=\"135\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"136\">Chương trình học</a></li>\n        <li data-kid=\"137\"><a href=\"#tinh-nang\" class=\"hover:text-white transition-colors\" data-kid=\"138\">Trợ lý AI</a></li>\n        <li data-kid=\"139\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"140\">Về chúng tôi</a></li>\n        <li data-kid=\"141\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"142\">Tài liệu tham khảo</a></li>\n      </ul>\n    </div>\n\n    <div class=\"reveal-up opacity-0\" style=\"transition-delay: 200ms;\" data-kid=\"143\">\n      <p class=\"mb-6 font-mono text-[10px] tracking-widest uppercase text-amber-500 font-bold\" data-kid=\"144\">Trạng thái nền tảng</p>\n      <p class=\"font-mono text-[11px] leading-loose text-stone-500 tracking-widest uppercase\" data-kid=\"145\">\n        HOẠT ĐỘNG 24/7 TOÀN CẦU<br data-kid=\"146\">\n        CẬP NHẬT CHƯƠNG TRÌNH 2025<br data-kid=\"147\">\n        DỮ LIỆU ĐÃ QUA XÁC THỰC\n      </p>\n    </div>\n  </div>\n\n  <div class=\"max-w-7xl mx-auto mt-24 pt-10 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-4 font-mono text-[10px] text-stone-600 tracking-widest uppercase\" data-kid=\"148\">\n    <span data-kid=\"149\">© 2026 Học Lịch Sử Việt Nam. Bản quyền được bảo lưu.</span>\n    <span data-kid=\"150\">Phát triển bởi Đội ngũ Giáo dục Số</span>\n  </div>\n</footer>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"151\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"152\"></script>\n<script data-kid=\"153\">\n  gsap.registerPlugin(ScrollTrigger);\n\n  window.addEventListener('load', () => {\n    // Set initial states for manifesto\n    gsap.set('.manifesto-line', { yPercent: 110 });\n\n    // 1. Hero Reveal\n    const heroTl = gsap.timeline();\n    heroTl.to('#hero-eyebrow', { opacity: 1, y: 0, duration: 1, ease: 'power3.out' })\n          .to('#hero-title', { opacity: 1, x: 0, duration: 1.2, ease: 'expo.out' }, '-=0.5')\n          .to('#hero-scroll', { opacity: 1, y: 0, duration: 1 }, '-=0.5')\n          .to('#progress-bar', { width: '65%', duration: 2, ease: 'power4.inOut' }, '-=0.8')\n          .to('#progress-val', { \n            duration: 2, \n            innerText: 65, \n            snap: { innerText: 1 },\n            onUpdate: function() {\n              document.getElementById('progress-val').innerText = Math.round(this.targets()[0].innerText) + '% TIẾN ĐỘ';\n            }\n          }, '-=2')\n          .to(['#hero-sub', '#hero-cta'], { opacity: 1, y: 0, stagger: 0.1, duration: 0.8 }, '-=1');\n\n    // 2. Stats Section Animations\n    gsap.from('#stats-rule', {\n      scaleY: 0,\n      scrollTrigger: {\n        trigger: '#chuong-trinh',\n        start: 'top 80%',\n      }\n    });\n\n    gsap.to('#stats-number', {\n      innerText: 6,\n      duration: 1.5,\n      snap: { innerText: 1 },\n      scrollTrigger: {\n        trigger: '#chuong-trinh',\n        start: 'top 70%',\n      }\n    });\n\n    gsap.from('.project-row', {\n      opacity: 0,\n      y: 30,\n      stagger: 0.1,\n      duration: 0.8,\n      ease: 'power2.out',\n      scrollTrigger: {\n        trigger: '#chuong-trinh',\n        start: 'top 60%',\n      }\n    });\n\n    // 3. Manifesto Scroll Effect\n    const manifestoSec = document.querySelector('.section-manifesto');\n    gsap.to(manifestoSec, {\n      backgroundColor: '#450a0a', // vn-red-950\n      color: '#ffffff',\n      scrollTrigger: {\n        trigger: '#manifesto',\n        start: 'top 60%',\n        end: 'bottom 40%',\n        toggleActions: 'play reverse play reverse',\n        scrub: 1\n      }\n    });\n\n    gsap.to('.manifesto-line', {\n      yPercent: 0,\n      stagger: 0.15,\n      duration: 1.2,\n      ease: 'power4.out',\n      scrollTrigger: {\n        trigger: '#manifesto',\n        start: 'top 60%',\n      }\n    });\n\n    gsap.to('#manifesto-tag', {\n      opacity: 1,\n      duration: 1,\n      scrollTrigger: {\n        trigger: '#manifesto',\n        start: 'top 30%',\n      }\n    });\n\n    // 4. Feature Cards (Bento)\n    gsap.to('#cases-heading', {\n      clipPath: 'inset(0 0% 0 0)',\n      duration: 1.2,\n      ease: 'power3.out',\n      scrollTrigger: {\n        trigger: '#tinh-nang',\n        start: 'top 80%',\n      }\n    });\n\n    gsap.to('#cases-label', {\n      opacity: 1,\n      duration: 1,\n      scrollTrigger: {\n        trigger: '#tinh-nang',\n        start: 'top 80%',\n      }\n    });\n\n    gsap.to('.case-card', {\n      opacity: 1,\n      y: 0,\n      stagger: 0.2,\n      duration: 1,\n      ease: 'power3.out',\n      scrollTrigger: {\n        trigger: '#tinh-nang',\n        start: 'top 60%',\n      }\n    });\n\n    // 5. Footer Animations\n    gsap.from(['#footer-rule-l', '#footer-rule-r'], {\n      scaleX: 0,\n      duration: 1.5,\n      ease: 'power4.inOut',\n      scrollTrigger: {\n        trigger: 'footer',\n        start: 'top 80%',\n      }\n    });\n\n    gsap.from('#footer-logo', {\n      opacity: 0,\n      y: 20,\n      duration: 1,\n      scrollTrigger: {\n        trigger: 'footer',\n        start: 'top 80%',\n      }\n    });\n\n    gsap.to('#footer-coord', {\n      opacity: 1,\n      duration: 1,\n      scrollTrigger: {\n        trigger: 'footer',\n        start: 'top 70%',\n      }\n    });\n\n    gsap.to('.reveal-up', {\n      opacity: 1,\n      y: 0,\n      stagger: 0.1,\n      duration: 1,\n      scrollTrigger: {\n        trigger: 'footer',\n        start: 'top 60%',\n      }\n    });\n\n    // Navbar scroll effect\n    window.addEventListener('scroll', () => {\n      const nav = document.getElementById('navbar');\n      if (window.scrollY > 100) {\n        nav.classList.add('nav-blur', 'py-4');\n      } else {\n        nav.classList.remove('nav-blur', 'py-4');\n      }\n    });\n  });\n</script>\n",
