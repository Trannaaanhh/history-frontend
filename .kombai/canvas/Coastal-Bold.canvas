    "node_paste_18649e5cbf0e": {
      "type": "variant",
      "id": "node_paste_18649e5cbf0e",
      "label": "Coastal Bold",
      "html": "<style>\n    *,\n    *::before,\n    *::after {\n      box-sizing: border-box;\n      margin: 0;\n      padding: 0;\n    }\n\n    :root {\n      --bg-primary: #F6F2EE;\n      --bg-secondary: #E3EBF0;\n      --text-primary: #1C2B36;\n      --text-muted: #617A8A;\n      --accent-1: #C8462A;\n      --accent-2: #2D8A9E;\n      --surface: #FFFFFF;\n      --font-display: 'Fraunces', Georgia, serif;\n      --font-body: 'DM Sans', sans-serif;\n      --font-mono: 'DM Mono', monospace;\n      --ease: cubic-bezier(0.25, 0, 0.15, 1);\n    }\n\n    html {\n      scroll-behavior: smooth;\n    }\n\n    body {\n      background: var(--bg-primary);\n      color: var(--text-primary);\n      font-family: var(--font-body);\n      font-size: 17px;\n      line-height: 1.65;\n      overflow-x: hidden;\n    }\n\n    /* ── HERO ── */\n    .hero {\n      position: relative;\n      width: 100%;\n      height: 100vh;\n      min-height: 600px;\n      overflow: hidden;\n    }\n\n    .hero-video {\n      position: absolute;\n      inset: 0;\n      width: 100%;\n      height: 100%;\n      object-fit: cover;\n      transform: scale(1.04);\n      transition: transform 2s var(--ease);\n      background: #2D3A42;\n    }\n\n    .hero-video.loaded {\n      transform: scale(1);\n    }\n\n    .hero-overlay {\n      position: absolute;\n      inset: 0;\n      background: linear-gradient(to bottom, rgba(28, 43, 54, 0.55) 0%, rgba(28, 43, 54, 0.15) 55%, rgba(28, 43, 54, 0.65) 100%);\n    }\n\n    .hero-content {\n      position: absolute;\n      left: 80px;\n      bottom: 80px;\n      z-index: 2;\n      max-width: 768px;\n    }\n\n    .hero-eyebrow {\n      font-family: var(--font-mono);\n      font-size: 11px;\n      letter-spacing: 0.12em;\n      color: var(--accent-2);\n      text-transform: uppercase;\n      margin-bottom: 14px;\n      opacity: 0;\n      transform: translateY(8px);\n      transition: opacity 0.6s var(--ease), transform 0.6s var(--ease);\n    }\n\n    .hero-eyebrow.is-in {\n      opacity: 1;\n      transform: none;\n    }\n\n    .hero-headline {\n      font-family: var(--font-display);\n      font-weight: 900;\n      font-style: italic;\n      font-size: clamp(40px, 4.2vw, 60px);\n      line-height: 1.0;\n      color: #F6F2EE;\n      margin-bottom: 16px;\n    }\n\n    .hero-word {\n      display: inline-block;\n      margin-right: 0.22em;\n      opacity: 0;\n      filter: blur(12px);\n      transition: opacity 0.7s var(--ease), filter 0.7s var(--ease);\n    }\n\n    .hero-word.is-in {\n      opacity: 1;\n      filter: blur(0);\n    }\n\n    .hero-elevation {\n      font-family: var(--font-mono);\n      font-size: 11px;\n      letter-spacing: 0.1em;\n      color: var(--accent-1);\n      text-transform: uppercase;\n      margin-bottom: 14px;\n      opacity: 0;\n      transition: opacity 0.6s var(--ease);\n    }\n\n    .hero-elevation.is-in {\n      opacity: 1;\n    }\n\n    .hero-sub {\n      font-size: 14px;\n      line-height: 1.5;\n      color: rgba(246, 242, 238, 0.82);\n      max-width: 420px;\n      margin-bottom: 20px;\n      opacity: 0;\n      transform: translateY(12px);\n      transition: opacity 0.8s var(--ease) 0.3s, transform 0.8s var(--ease) 0.3s;\n    }\n\n    .hero-sub.is-in {\n      opacity: 1;\n      transform: none;\n    }\n\n    .hero-cta {\n      display: inline-block;\n      font-family: var(--font-body);\n      font-weight: 500;\n      font-size: 13px;\n      letter-spacing: 0.06em;\n      text-transform: uppercase;\n      color: #fff;\n      border: 1.5px solid rgba(255, 255, 255, 0.5);\n      padding: 11px 24px;\n      text-decoration: none;\n      opacity: 0;\n      transform: translateY(12px);\n      transition: opacity 0.8s var(--ease) 0.5s, transform 0.8s var(--ease) 0.5s, background 0.25s, border-color 0.25s, color 0.25s;\n    }\n\n    .hero-cta.is-in {\n      opacity: 1;\n      transform: none;\n    }\n\n    .hero-cta:hover {\n      background: var(--accent-1);\n      border-color: var(--accent-1);\n      color: #fff;\n    }\n\n    .hero-coord {\n      position: absolute;\n      bottom: 40px;\n      right: 80px;\n      font-family: var(--font-mono);\n      font-size: 11px;\n      letter-spacing: 0.1em;\n      color: rgba(246, 242, 238, 0.6);\n      text-transform: uppercase;\n      z-index: 2;\n    }\n\n    /* ── NAV ── */\n    nav {\n      position: fixed;\n      top: 0;\n      left: 0;\n      right: 0;\n      z-index: 100;\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n      padding: 28px 80px;\n      background: transparent;\n    }\n\n    .nav-logo {\n      font-family: var(--font-display);\n      font-weight: 900;\n      font-style: italic;\n      font-size: 22px;\n      color: #F6F2EE;\n      text-decoration: none;\n      letter-spacing: -0.01em;\n    }\n\n    .nav-links {\n      display: flex;\n      gap: 40px;\n      list-style: none;\n    }\n\n    .nav-links a {\n      font-family: var(--font-mono);\n      font-size: 12px;\n      letter-spacing: 0.1em;\n      text-transform: uppercase;\n      color: rgba(246, 242, 238, 0.75);\n      text-decoration: none;\n      transition: color 0.2s;\n    }\n\n    .nav-links a:hover {\n      color: #F6F2EE;\n    }\n\n    /* ── SECTION 1 — WORK ── */\n    .section-work {\n      display: grid;\n      grid-template-columns: 1fr 1fr;\n      min-height: 100vh;\n      background: var(--bg-primary);\n    }\n\n    .work-left {\n      position: sticky;\n      top: 120px;\n      height: fit-content;\n      padding: 120px 64px 80px 80px;\n      align-self: start;\n    }\n\n    .work-rule {\n      width: 3px;\n      height: 56px;\n      background: var(--accent-1);\n      margin-bottom: 36px;\n      transform: scaleY(0);\n      transform-origin: top;\n      transition: transform 0.6s var(--ease);\n    }\n\n    .work-rule.is-in {\n      transform: scaleY(1);\n    }\n\n    .work-label {\n      font-family: var(--font-mono);\n      font-size: 11px;\n      letter-spacing: 0.14em;\n      text-transform: uppercase;\n      color: var(--accent-2);\n      margin-bottom: 20px;\n      opacity: 0;\n      transition: opacity 0.6s var(--ease) 0.1s;\n    }\n\n    .work-label.is-in {\n      opacity: 1;\n    }\n\n    .work-heading {\n      font-family: var(--font-display);\n      font-weight: 700;\n      font-style: italic;\n      font-size: clamp(40px, 4vw, 56px);\n      line-height: 1.08;\n      color: var(--text-primary);\n      margin-bottom: 28px;\n      clip-path: inset(0 100% 0 0);\n      transition: clip-path 0.9s var(--ease) 0.15s;\n    }\n\n    .work-heading.is-in {\n      clip-path: inset(0 0% 0 0);\n    }\n\n    .work-stat {\n      font-family: var(--font-display);\n      font-weight: 900;\n      font-style: italic;\n      font-size: 64px;\n      color: var(--accent-1);\n      line-height: 1;\n      margin-bottom: 8px;\n      opacity: 0;\n      transition: opacity 0.6s var(--ease) 0.4s;\n    }\n\n    .work-stat.is-in {\n      opacity: 1;\n    }\n\n    .work-stat-label {\n      font-family: var(--font-mono);\n      font-size: 11px;\n      letter-spacing: 0.12em;\n      text-transform: uppercase;\n      color: var(--text-muted);\n      margin-bottom: 32px;\n      opacity: 0;\n      transition: opacity 0.6s var(--ease) 0.5s;\n    }\n\n    .work-stat-label.is-in {\n      opacity: 1;\n    }\n\n    .work-body {\n      font-size: 16px;\n      color: var(--text-muted);\n      max-width: 360px;\n      margin-bottom: 40px;\n      opacity: 0;\n      transform: translateY(16px);\n      transition: opacity 0.8s var(--ease) 0.5s, transform 0.8s var(--ease) 0.5s;\n    }\n\n    .work-body.is-in {\n      opacity: 1;\n      transform: none;\n    }\n\n    .work-cta {\n      display: inline-block;\n      font-family: var(--font-body);\n      font-weight: 500;\n      font-size: 14px;\n      letter-spacing: 0.06em;\n      text-transform: uppercase;\n      color: var(--accent-1);\n      text-decoration: none;\n      border-bottom: 1.5px solid var(--accent-1);\n      padding-bottom: 4px;\n      opacity: 0;\n      transition: opacity 0.6s var(--ease) 0.7s, color 0.2s, border-color 0.2s;\n    }\n\n    .work-cta.is-in {\n      opacity: 1;\n    }\n\n    .work-cta:hover {\n      color: var(--accent-2);\n      border-color: var(--accent-2);\n    }\n\n    .work-right {\n      padding: 120px 80px 120px 48px;\n      border-left: 1px solid rgba(28, 43, 54, 0.1);\n    }\n\n    .project-row {\n      padding: 28px 0;\n      border-bottom: 1px solid rgba(28, 43, 54, 0.1);\n      display: grid;\n      grid-template-columns: 40px 1fr auto;\n      align-items: baseline;\n      gap: 20px;\n      cursor: pointer;\n      position: relative;\n      opacity: 0;\n      transform: translateY(24px);\n      transition: opacity 0.7s var(--ease), transform 0.7s var(--ease);\n    }\n\n    .project-row.is-in {\n      opacity: 1;\n      transform: none;\n    }\n\n    .project-row::after {\n      content: '';\n      position: absolute;\n      bottom: -1px;\n      left: 0;\n      width: 0;\n      height: 1.5px;\n      background: var(--accent-1);\n      transition: width 0.3s var(--ease);\n    }\n\n    .project-row:hover::after {\n      width: 100%;\n    }\n\n    .project-num {\n      font-family: var(--font-mono);\n      font-size: 11px;\n      color: var(--text-muted);\n      letter-spacing: 0.08em;\n    }\n\n    .project-title {\n      font-family: var(--font-display);\n      font-weight: 600;\n      font-style: italic;\n      font-size: 22px;\n      color: var(--text-primary);\n      transition: color 0.2s;\n    }\n\n    .project-row:hover .project-title {\n      color: var(--accent-1);\n    }\n\n    .project-cat {\n      font-family: var(--font-mono);\n      font-size: 11px;\n      letter-spacing: 0.1em;\n      text-transform: uppercase;\n      color: var(--accent-2);\n    }\n\n    /* ── SECTION 2 — MANIFESTO ── */\n    .section-manifesto {\n      padding: 160px 80px;\n      text-align: center;\n      position: relative;\n      overflow: hidden;\n      background: var(--bg-primary);\n      transition: background 0.5s ease, color 0.5s ease;\n    }\n\n    .section-manifesto.dark {\n      background: var(--text-primary);\n      color: var(--bg-primary);\n    }\n\n    .manifesto-line-wrap {\n      overflow: hidden;\n      margin-bottom: 4px;\n    }\n\n    .manifesto-line {\n      font-family: var(--font-display);\n      font-weight: 900;\n      font-style: italic;\n      font-size: clamp(36px, 5vw, 60px);\n      line-height: 1.12;\n      display: block;\n      transform: translateY(100%);\n      transition: transform 0.8s var(--ease);\n      color: inherit;\n    }\n\n    .manifesto-line.is-in {\n      transform: translateY(0);\n    }\n\n    .manifesto-tag {\n      font-family: var(--font-mono);\n      font-size: 12px;\n      letter-spacing: 0.14em;\n      text-transform: uppercase;\n      color: var(--accent-2);\n      margin-top: 60px;\n      opacity: 0;\n      transition: opacity 0.8s var(--ease) 0.6s;\n    }\n\n    .manifesto-tag.is-in {\n      opacity: 1;\n    }\n\n    /* ── SECTION 3 — CASE STUDIES ── */\n    .section-cases {\n      padding: 120px 80px;\n      background: var(--bg-secondary);\n    }\n\n    .cases-header {\n      display: flex;\n      align-items: baseline;\n      justify-content: space-between;\n      margin-bottom: 72px;\n    }\n\n    .cases-heading {\n      font-family: var(--font-display);\n      font-weight: 700;\n      font-style: italic;\n      font-size: clamp(36px, 4vw, 52px);\n      color: var(--text-primary);\n      opacity: 0;\n      clip-path: inset(0 100% 0 0);\n      transition: clip-path 0.9s var(--ease), opacity 0s;\n    }\n\n    .cases-heading.is-in {\n      clip-path: inset(0 0% 0 0);\n      opacity: 1;\n    }\n\n    .cases-label {\n      font-family: var(--font-mono);\n      font-size: 11px;\n      letter-spacing: 0.12em;\n      text-transform: uppercase;\n      color: var(--text-muted);\n      opacity: 0;\n      transition: opacity 0.6s var(--ease) 0.3s;\n    }\n\n    .cases-label.is-in {\n      opacity: 1;\n    }\n\n    .cases-grid {\n      display: grid;\n      grid-template-columns: repeat(3, 1fr);\n      gap: 28px;\n    }\n\n    .case-card {\n      background: var(--surface);\n      border-top: 4px solid var(--accent-1);\n      overflow: hidden;\n      opacity: 0;\n      transition: opacity 0.7s var(--ease), transform 0.7s var(--ease), box-shadow 0.3s;\n    }\n\n    .case-card:hover {\n      box-shadow: 0 12px 40px rgba(28, 43, 54, 0.12);\n    }\n\n    .case-card.from-left {\n      transform: translateX(-80px);\n    }\n\n    .case-card.from-right {\n      transform: translateX(80px);\n    }\n\n    .case-card.is-in {\n      opacity: 1;\n      transform: none;\n    }\n\n    .case-img {\n      width: 100%;\n      aspect-ratio: 3/2;\n      object-fit: cover;\n      display: block;\n      background: var(--accent-2);\n      min-height: 200px;\n    }\n\n    .case-body {\n      padding: 28px 28px 32px;\n    }\n\n    .case-cat {\n      font-family: var(--font-mono);\n      font-size: 11px;\n      letter-spacing: 0.12em;\n      text-transform: uppercase;\n      color: var(--accent-2);\n      margin-bottom: 10px;\n    }\n\n    .case-title {\n      font-family: var(--font-display);\n      font-weight: 600;\n      font-style: italic;\n      font-size: 22px;\n      line-height: 1.2;\n      color: var(--text-primary);\n      margin-bottom: 10px;\n    }\n\n    .case-desc {\n      font-size: 14px;\n      color: var(--text-muted);\n      line-height: 1.55;\n      margin-bottom: 20px;\n    }\n\n    .case-link {\n      font-family: var(--font-mono);\n      font-size: 12px;\n      letter-spacing: 0.08em;\n      text-transform: uppercase;\n      color: var(--accent-2);\n      text-decoration: none;\n      display: inline-flex;\n      align-items: center;\n      gap: 8px;\n      transition: color 0.2s;\n    }\n\n    .case-link:hover {\n      color: var(--accent-1);\n    }\n\n    .case-link::after {\n      content: '→';\n    }\n\n    /* ── FOOTER ── */\n    footer {\n      background: var(--text-primary);\n      color: var(--bg-primary);\n      padding: 100px 80px 60px;\n      position: relative;\n      overflow: hidden;\n    }\n\n    .footer-rule-wrap {\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      gap: 32px;\n      margin-bottom: 40px;\n    }\n\n    .footer-rule {\n      flex: 1;\n      height: 2px;\n      background: var(--accent-1);\n      transform: scaleX(0);\n      transition: transform 0.8s var(--ease);\n    }\n\n    .footer-rule.left {\n      transform-origin: right;\n    }\n\n    .footer-rule.right {\n      transform-origin: left;\n    }\n\n    .footer-rule.is-in {\n      transform: scaleX(1);\n    }\n\n    .footer-wordmark {\n      font-family: var(--font-display);\n      font-weight: 900;\n      font-style: italic;\n      font-size: clamp(36px, 5vw, 56px);\n      color: var(--bg-primary);\n      white-space: nowrap;\n      letter-spacing: -0.01em;\n    }\n\n    .footer-char {\n      display: inline-block;\n      clip-path: inset(0 100% 0 0);\n      transition: clip-path 0.5s var(--ease);\n    }\n\n    .footer-char.is-in {\n      clip-path: inset(0 0% 0 0);\n    }\n\n    .footer-elevation {\n      font-family: var(--font-mono);\n      font-size: 12px;\n      letter-spacing: 0.14em;\n      text-transform: uppercase;\n      color: var(--text-muted);\n      text-align: center;\n      margin-bottom: 72px;\n      opacity: 0;\n      transition: opacity 0.6s var(--ease) 0.5s;\n    }\n\n    .footer-elevation.is-in {\n      opacity: 1;\n    }\n\n    .footer-grid {\n      display: grid;\n      grid-template-columns: 1fr 1fr 1fr;\n      gap: 40px;\n      padding-top: 40px;\n      border-top: 1px solid rgba(246, 242, 238, 0.12);\n    }\n\n    .footer-col-label {\n      font-family: var(--font-mono);\n      font-size: 11px;\n      letter-spacing: 0.12em;\n      text-transform: uppercase;\n      color: var(--text-muted);\n      margin-bottom: 16px;\n    }\n\n    .footer-name {\n      font-family: var(--font-display);\n      font-weight: 700;\n      font-style: italic;\n      font-size: 20px;\n      color: var(--bg-primary);\n      margin-bottom: 8px;\n    }\n\n    .footer-email {\n      font-size: 15px;\n      color: var(--accent-2);\n      text-decoration: none;\n    }\n\n    .footer-email:hover {\n      color: var(--accent-1);\n    }\n\n    .footer-nav {\n      list-style: none;\n      display: flex;\n      flex-direction: column;\n      gap: 12px;\n    }\n\n    .footer-nav a {\n      font-size: 15px;\n      color: rgba(246, 242, 238, 0.65);\n      text-decoration: none;\n      transition: color 0.2s;\n    }\n\n    .footer-nav a:hover {\n      color: var(--bg-primary);\n    }\n\n    .footer-avail {\n      font-family: var(--font-mono);\n      font-size: 12px;\n      letter-spacing: 0.1em;\n      text-transform: uppercase;\n      color: var(--accent-1);\n      margin-bottom: 12px;\n    }\n\n    .footer-coords {\n      font-family: var(--font-mono);\n      font-size: 11px;\n      color: var(--text-muted);\n      letter-spacing: 0.08em;\n      line-height: 1.8;\n    }\n\n    .footer-base {\n      margin-top: 60px;\n      padding-top: 24px;\n      border-top: 1px solid rgba(246, 242, 238, 0.08);\n      display: flex;\n      justify-content: space-between;\n      align-items: center;\n    }\n\n    .footer-copy {\n      font-family: var(--font-mono);\n      font-size: 11px;\n      letter-spacing: 0.08em;\n      color: var(--text-muted);\n    }\n\n    /* ── RESPONSIVE ── */\n    @media (max-width: 768px) {\n      nav {\n        padding: 24px 24px;\n      }\n\n      .nav-links {\n        display: none;\n      }\n\n      .hero-content {\n        left: 24px;\n        right: 24px;\n        bottom: 64px;\n        max-width: none;\n      }\n\n      .hero-coord {\n        right: 24px;\n        font-size: 10px;\n      }\n\n      .hero-headline {\n        font-size: clamp(34px, 8vw, 48px);\n      }\n\n      .section-work {\n        grid-template-columns: 1fr;\n      }\n\n      .work-left {\n        position: static;\n        padding: 80px 24px 40px;\n      }\n\n      .work-right {\n        padding: 0 24px 80px;\n        border-left: none;\n        border-top: 1px solid rgba(28, 43, 54, 0.1);\n      }\n\n      .section-manifesto {\n        padding: 100px 24px;\n      }\n\n      .manifesto-line {\n        font-size: clamp(28px, 8vw, 44px);\n      }\n\n      .section-cases {\n        padding: 80px 24px;\n      }\n\n      .cases-grid {\n        grid-template-columns: 1fr;\n      }\n\n      .case-card.from-left,\n      .case-card.from-right {\n        transform: translateY(40px);\n      }\n\n      .footer-grid {\n        grid-template-columns: 1fr;\n        gap: 32px;\n      }\n\n      footer {\n        padding: 72px 24px 48px;\n      }\n\n      .footer-wordmark {\n        font-size: clamp(28px, 9vw, 40px);\n      }\n\n      .footer-base {\n        flex-direction: column;\n        gap: 8px;\n        text-align: center;\n      }\n    }\n  </style>\n<link     href=\"https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;0,9..144,900;1,9..144,600;1,9..144,700;1,9..144,900&family=DM+Sans:wght@400;500&family=DM+Mono&display=swap\"\n    rel=\"stylesheet\" onerror=\"__crawlAsset&&__crawlAsset(this)\">\n\n\n  \n  <nav data-kid=\"0\">\n    <a class=\"nav-logo\" href=\"#\" data-kid=\"1\">Coastal</a>\n    <ul class=\"nav-links\" data-kid=\"2\">\n      <li data-kid=\"3\"><a href=\"#work\" data-kid=\"4\">Work</a></li>\n      <li data-kid=\"5\"><a href=\"#manifesto\" data-kid=\"6\">Studio</a></li>\n      <li data-kid=\"7\"><a href=\"#cases\" data-kid=\"8\">Cases</a></li>\n      <li data-kid=\"9\"><a href=\"#contact\" data-kid=\"10\">Contact</a></li>\n    </ul>\n  </nav>\n\n  \n  <section class=\"hero\" data-kid=\"11\">\n    <video class=\"hero-video\" autoplay loop muted playsinline poster=\"https://kombai-assets-dev.b-cdn.net/generated_assets/7_landing_page_for_a_coastal_bold_design_studio/assets/hero.png\" onerror=\"this.style.display='none'\" data-kid=\"12\">\n      <source src=\"https://kombai-assets-dev.b-cdn.net/generated_assets/7_landing_page_for_a_coastal_bold_design_studio/assets/hero.mp4\" type=\"video/mp4\" data-kid=\"13\">\n    </video>\n    <div class=\"hero-overlay\" data-kid=\"14\"></div>\n    <div class=\"hero-content\" data-kid=\"15\">\n      <p class=\"hero-eyebrow\" data-kid=\"16\">Design Studio · Atlantic Coast</p>\n      <h1 class=\"hero-headline\" data-kid=\"17\">\n        <span class=\"hero-word\" data-kid=\"18\">Stand</span>\n        <span class=\"hero-word\" data-kid=\"19\">at</span>\n        <span class=\"hero-word\" data-kid=\"20\">the</span>\n        <span class=\"hero-word\" data-kid=\"21\">edge.</span>\n      </h1>\n      <p class=\"hero-elevation\" id=\"elevation-counter\" data-kid=\"22\">0m ELEVATION</p>\n      <p class=\"hero-sub\" data-kid=\"23\">A design studio built for brands that demand the best — where strategy, identity, and craft\n        hold up against the elements.</p>\n      <a class=\"hero-cta\" href=\"#work\" data-kid=\"24\">See Our Work</a>\n    </div>\n    <div class=\"hero-coord\" data-kid=\"25\">51.4°N / 9.8°W · MIZEN HEAD</div>\n  </section>\n\n  \n  <section class=\"section-work\" id=\"work\" data-kid=\"26\">\n    <div class=\"work-left\" data-kid=\"27\">\n      <div class=\"work-rule\" data-kid=\"28\"></div>\n      <p class=\"work-label\" data-kid=\"29\">Selected Work</p>\n      <h2 class=\"work-heading\" data-kid=\"30\">Brands built<br data-kid=\"31\">to withstand.</h2>\n      <div class=\"work-stat\" id=\"work-stat\" data-kid=\"32\">0</div>\n      <p class=\"work-stat-label\" data-kid=\"33\">Projects Delivered</p>\n      <p class=\"work-body\" data-kid=\"34\">From coastal hospitality to marine conservation, we build identity systems and digital\n        platforms that are honest, bold, and built to last.</p>\n      <a class=\"work-cta\" href=\"#cases\" data-kid=\"35\">View All Work</a>\n    </div>\n    <div class=\"work-right\" data-kid=\"36\">\n      <div class=\"project-row\" data-kid=\"37\">\n        <span class=\"project-num\" data-kid=\"38\">01</span>\n        <span class=\"project-title\" data-kid=\"39\">Mizen Head Tourism Board</span>\n        <span class=\"project-cat\" data-kid=\"40\">Brand Identity</span>\n      </div>\n      <div class=\"project-row\" data-kid=\"41\">\n        <span class=\"project-num\" data-kid=\"42\">02</span>\n        <span class=\"project-title\" data-kid=\"43\">Atlantic Conservation Trust</span>\n        <span class=\"project-cat\" data-kid=\"44\">Campaign + Print</span>\n      </div>\n      <div class=\"project-row\" data-kid=\"45\">\n        <span class=\"project-num\" data-kid=\"46\">03</span>\n        <span class=\"project-title\" data-kid=\"47\">Saltrock Hospitality Group</span>\n        <span class=\"project-cat\" data-kid=\"48\">Digital Platform</span>\n      </div>\n      <div class=\"project-row\" data-kid=\"49\">\n        <span class=\"project-num\" data-kid=\"50\">04</span>\n        <span class=\"project-title\" data-kid=\"51\">Cove Distillery</span>\n        <span class=\"project-cat\" data-kid=\"52\">Packaging + Brand</span>\n      </div>\n      <div class=\"project-row\" data-kid=\"53\">\n        <span class=\"project-num\" data-kid=\"54\">05</span>\n        <span class=\"project-title\" data-kid=\"55\">Open Water Foundation</span>\n        <span class=\"project-cat\" data-kid=\"56\">Identity + Motion</span>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"section-manifesto\" id=\"manifesto\" data-kid=\"57\">\n    <div class=\"manifesto-line-wrap\" data-kid=\"58\"><span class=\"manifesto-line\" data-kid=\"59\">We build at the edge.</span></div>\n    <div class=\"manifesto-line-wrap\" data-kid=\"60\"><span class=\"manifesto-line\" data-kid=\"61\">Where clarity costs something.</span></div>\n    <div class=\"manifesto-line-wrap\" data-kid=\"62\"><span class=\"manifesto-line\" data-kid=\"63\">Where the brief is honest.</span></div>\n    <div class=\"manifesto-line-wrap\" data-kid=\"64\"><span class=\"manifesto-line\" data-kid=\"65\">Where the work is tested by wind.</span></div>\n    <div class=\"manifesto-line-wrap\" data-kid=\"66\"><span class=\"manifesto-line\" data-kid=\"67\">We are coastal-bold.</span></div>\n    <p class=\"manifesto-tag\" data-kid=\"68\">est. 2014 · 60+ projects · 4 continents</p>\n  </section>\n\n  \n  <section class=\"section-cases\" id=\"cases\" data-kid=\"69\">\n    <div class=\"cases-header\" data-kid=\"70\">\n      <h2 class=\"cases-heading\" data-kid=\"71\">Case Studies</h2>\n      <span class=\"cases-label\" data-kid=\"72\">Three of sixty</span>\n    </div>\n    <div class=\"cases-grid\" data-kid=\"73\">\n      <div class=\"case-card from-left\" data-kid=\"74\">\n        <img class=\"case-img\" src=\"https://kombai-assets-dev.b-cdn.net/generated_assets/7_landing_page_for_a_coastal_bold_design_studio/assets/work/coastal-01.png\" alt=\"Coastal Tourism Brand\" onerror=\"this.style.display='none'\" data-kid=\"75\">\n        <div class=\"case-body\" data-kid=\"76\">\n          <p class=\"case-cat\" data-kid=\"77\">Brand Identity</p>\n          <h3 class=\"case-title\" data-kid=\"78\">Mizen Head Tourism Board</h3>\n          <p class=\"case-desc\" data-kid=\"79\">A bold regional identity rooted in the dramatic southwest Irish coast — wayfinding,\n            print, and digital presence.</p>\n          <a class=\"case-link\" href=\"#\" data-kid=\"80\">View Case</a>\n        </div>\n      </div>\n      <div class=\"case-card from-left\" data-kid=\"81\">\n        <img class=\"case-img\" src=\"https://kombai-assets-dev.b-cdn.net/generated_assets/7_landing_page_for_a_coastal_bold_design_studio/assets/work/coastal-02.png\" alt=\"Marine Conservation\" onerror=\"this.style.display='none'\" data-kid=\"82\">\n        <div class=\"case-body\" data-kid=\"83\">\n          <p class=\"case-cat\" data-kid=\"84\">Campaign + Print</p>\n          <h3 class=\"case-title\" data-kid=\"85\">Atlantic Conservation Trust</h3>\n          <p class=\"case-desc\" data-kid=\"86\">A fundraising campaign that brought the scale of ocean loss into living rooms and\n            boardrooms worldwide.</p>\n          <a class=\"case-link\" href=\"#\" data-kid=\"87\">View Case</a>\n        </div>\n      </div>\n      <div class=\"case-card from-left\" data-kid=\"88\">\n        <img class=\"case-img\" src=\"https://kombai-assets-dev.b-cdn.net/generated_assets/7_landing_page_for_a_coastal_bold_design_studio/assets/work/coastal-03.png\" alt=\"Hospitality Digital Platform\" onerror=\"this.style.display='none'\" data-kid=\"89\">\n        <div class=\"case-body\" data-kid=\"90\">\n          <p class=\"case-cat\" data-kid=\"91\">Digital Platform</p>\n          <h3 class=\"case-title\" data-kid=\"92\">Saltrock Hospitality Group</h3>\n          <p class=\"case-desc\" data-kid=\"93\">A booking and brand platform for seven coastal properties — built for conversion,\n            designed for the landscape.</p>\n          <a class=\"case-link\" href=\"#\" data-kid=\"94\">View Case</a>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <footer id=\"contact\" data-kid=\"95\">\n    <div class=\"footer-rule-wrap\" data-kid=\"96\">\n      <div class=\"footer-rule left\" data-kid=\"97\"></div>\n      <div class=\"footer-wordmark\" id=\"footer-wordmark\" data-kid=\"98\">COASTAL</div>\n      <div class=\"footer-rule right\" data-kid=\"99\"></div>\n    </div>\n    <p class=\"footer-elevation\" data-kid=\"100\">312m · MIZEN HEAD · 51.4°N</p>\n    <div class=\"footer-grid\" data-kid=\"101\">\n      <div data-kid=\"102\">\n        <p class=\"footer-col-label\" data-kid=\"103\">Studio</p>\n        <p class=\"footer-name\" data-kid=\"104\">Coastal Design</p>\n        <a class=\"footer-email\" href=\"mailto:hello@coastaldesign.co\" data-kid=\"105\">hello@coastaldesign.co</a>\n      </div>\n      <div data-kid=\"106\">\n        <p class=\"footer-col-label\" data-kid=\"107\">Navigate</p>\n        <ul class=\"footer-nav\" data-kid=\"108\">\n          <li data-kid=\"109\"><a href=\"#work\" data-kid=\"110\">Work</a></li>\n          <li data-kid=\"111\"><a href=\"#manifesto\" data-kid=\"112\">Studio</a></li>\n          <li data-kid=\"113\"><a href=\"#cases\" data-kid=\"114\">Cases</a></li>\n          <li data-kid=\"115\"><a href=\"#contact\" data-kid=\"116\">Contact</a></li>\n        </ul>\n      </div>\n      <div data-kid=\"117\">\n        <p class=\"footer-avail\" data-kid=\"118\">Available Now</p>\n        <p class=\"footer-coords\" data-kid=\"119\">Atlantic Coast, Ireland<br data-kid=\"120\">51.4°N / 9.8°W<br data-kid=\"121\">GMT · Open to remote worldwide</p>\n      </div>\n    </div>\n    <div class=\"footer-base\" data-kid=\"122\">\n      <span class=\"footer-copy\" data-kid=\"123\">© 2026 Coastal Design Studio. All rights reserved.</span>\n      <span class=\"footer-copy\" data-kid=\"124\">Mizen Head, Ireland</span>\n    </div>\n  </footer>\n\n  <script data-kid=\"125\">\n    // Hero video settle\n    window.addEventListener('load', () => {\n      const v = document.querySelector('.hero-video');\n      if (v) v.classList.add('loaded');\n    });\n\n    // Hero eyebrow\n    const eyebrow = document.querySelector('.hero-eyebrow');\n    setTimeout(() => { if (eyebrow) eyebrow.classList.add('is-in'); }, 200);\n\n    // Hero words blur-to-sharp stagger\n    const words = document.querySelectorAll('.hero-word');\n    words.forEach((w, i) => {\n      setTimeout(() => w.classList.add('is-in'), 400 + i * 120);\n    });\n\n    // Elevation counter\n    const elCounter = document.getElementById('elevation-counter');\n    if (elCounter) {\n      setTimeout(() => {\n        elCounter.classList.add('is-in');\n        let start = null;\n        const target = 312;\n        const dur = 1800;\n        function step(ts) {\n          if (!start) start = ts;\n          const p = Math.min((ts - start) / dur, 1);\n          const ease = 1 - Math.pow(1 - p, 3);\n          elCounter.textContent = Math.round(ease * target) + 'm ELEVATION';\n          if (p < 1) requestAnimationFrame(step);\n        }\n        requestAnimationFrame(step);\n      }, 700);\n    }\n\n    // Hero sub + CTA\n    setTimeout(() => {\n      const sub = document.querySelector('.hero-sub');\n      const cta = document.querySelector('.hero-cta');\n      if (sub) sub.classList.add('is-in');\n      if (cta) cta.classList.add('is-in');\n    }, 900);\n\n    // Work count-up\n    let workCounted = false;\n    function countUp(el, target, dur) {\n      let start = null;\n      function step(ts) {\n        if (!start) start = ts;\n        const p = Math.min((ts - start) / dur, 1);\n        const ease = 1 - Math.pow(1 - p, 3);\n        el.textContent = Math.round(ease * target) + '+';\n        if (p < 1) requestAnimationFrame(step);\n      }\n      requestAnimationFrame(step);\n    }\n\n    // Manifesto scroll scrub\n    const manifestoSection = document.querySelector('.section-manifesto');\n    let scrollY = 0;\n    let ticking = false;\n\n    function updateScroll() {\n      ticking = false;\n      if (manifestoSection) {\n        const rect = manifestoSection.getBoundingClientRect();\n        const wh = window.innerHeight;\n        const progress = Math.max(0, Math.min(1, (wh - rect.top) / (wh + rect.height)));\n        if (progress > 0.3) {\n          manifestoSection.classList.add('dark');\n        } else {\n          manifestoSection.classList.remove('dark');\n        }\n      }\n    }\n\n    window.addEventListener('scroll', () => {\n      scrollY = window.scrollY;\n      if (!ticking) {\n        requestAnimationFrame(updateScroll);\n        ticking = true;\n      }\n    }, { passive: true });\n\n    // IntersectionObserver for all animated elements\n    const animEls = document.querySelectorAll(\n      '.work-rule, .work-label, .work-heading, .work-stat, .work-stat-label, .work-body, .work-cta, ' +\n      '.project-row, .manifesto-line, .manifesto-tag, ' +\n      '.cases-heading, .cases-label, .case-card, ' +\n      '.footer-rule, .footer-elevation'\n    );\n\n    const obs = new IntersectionObserver((entries) => {\n      entries.forEach(entry => {\n        if (entry.isIntersecting) {\n          const el = entry.target;\n          if (el.classList.contains('project-row')) {\n            const siblings = Array.from(el.parentElement.querySelectorAll('.project-row'));\n            const idx = siblings.indexOf(el);\n            setTimeout(() => el.classList.add('is-in'), idx * 80);\n          } else if (el.classList.contains('manifesto-line')) {\n            const wraps = Array.from(document.querySelectorAll('.manifesto-line'));\n            const idx = wraps.indexOf(el);\n            setTimeout(() => el.classList.add('is-in'), idx * 80);\n          } else if (el.classList.contains('case-card')) {\n            const cards = Array.from(document.querySelectorAll('.case-card'));\n            const idx = cards.indexOf(el);\n            setTimeout(() => el.classList.add('is-in'), idx * 120);\n          } else if (el.classList.contains('work-stat')) {\n            el.classList.add('is-in');\n            if (!workCounted) {\n              workCounted = true;\n              countUp(el, 60, 1400);\n            }\n          } else {\n            el.classList.add('is-in');\n          }\n          obs.unobserve(el);\n        }\n      });\n    }, { threshold: 0 });\n\n    animEls.forEach(el => obs.observe(el));\n\n    // Footer char reveal\n    const wordmark = document.getElementById('footer-wordmark');\n    if (wordmark) {\n      const text = wordmark.textContent;\n      wordmark.innerHTML = '';\n      text.split('').forEach((ch, i) => {\n        const span = document.createElement('span');\n        span.className = 'footer-char';\n        span.textContent = ch === ' ' ? ' ' : ch;\n        wordmark.appendChild(span);\n      });\n\n      const footerObs = new IntersectionObserver((entries) => {\n        entries.forEach(entry => {\n          if (entry.isIntersecting) {\n            document.querySelectorAll('.footer-char').forEach((ch, i) => {\n              setTimeout(() => ch.classList.add('is-in'), i * 40);\n            });\n            footerObs.disconnect();\n          }\n        });\n      }, { threshold: 0 });\n\n      footerObs.observe(wordmark);\n    }\n\n    // Global fallback: ensure all animated elements become visible\n    setTimeout(() => {\n      document.querySelectorAll(\n        '.work-rule, .work-label, .work-heading, .work-stat, .work-stat-label, .work-body, .work-cta, ' +\n        '.project-row, .manifesto-line, .manifesto-tag, ' +\n        '.cases-heading, .cases-label, .case-card, ' +\n        '.footer-rule, .footer-elevation, .footer-char'\n      ).forEach(el => {\n        if (!el.classList.contains('is-in')) el.classList.add('is-in');\n      });\n      if (!workCounted) {\n        const stat = document.getElementById('work-stat');\n        if (stat) { workCounted = true; countUp(stat, 60, 1400); }\n      }\n    }, 1500);\n  </script>\n",
