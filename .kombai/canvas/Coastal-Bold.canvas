      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;0,9..144,900;1,9..144,400;1,9..144,600;1,9..144,700;1,9..144,900&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap');\n\n  :root {\n    --vn-red: #DC2626;\n    --vn-gold: #D97706;\n    --vn-red-800: #991B1B;\n    --vn-red-950: #450a0a;\n    --vn-stone-50: #fafaf9;\n    --ease: cubic-bezier(0.25, 0, 0.15, 1);\n  }\n\n  body {\n    background-color: var(--vn-stone-50);\n    color: #1c1917;\n    font-family: 'Inter', sans-serif;\n    overflow-x: clip;\n    position: relative;\n  }\n\n  body::before {\n    content: \"\";\n    position: fixed;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100%;\n    background-image: url(\"https://www.transparenttextures.com/patterns/natural-paper.png\");\n    opacity: 0.12;\n    pointer-events: none;\n    z-index: 9999;\n  }\n\n  .font-display { font-family: 'Fraunces', serif; }\n  .font-mono { font-family: 'IBM Plex Mono', monospace; }\n\n  /* Hero Animations Classes (Resting states) */\n  .reveal-text {\n    clip-path: inset(0 100% 0 0);\n  }\n\n  /* Sticky section fix */\n  .sticky-parent {\n    position: relative;\n    overflow: visible;\n  }\n\n  /* Manifesto lines */\n  .manifesto-line-wrap {\n    overflow: hidden;\n  }\n  .manifesto-line {\n    display: block;\n  }\n\n  .nav-blur {\n    backdrop-filter: blur(10px);\n    background: rgba(255, 255, 255, 0.05);\n  }\n\n  /* Custom Scrollbar */\n  ::-webkit-scrollbar { width: 6px; }\n  ::-webkit-scrollbar-track { background: var(--vn-stone-50); }\n  ::-webkit-scrollbar-thumb { background: var(--vn-red); border-radius: 10px; }\n</style>\n\n\n<nav id=\"navbar\" class=\"fixed top-0 left-0 right-0 z-[100] flex items-center justify-between px-12 py-8 transition-all duration-500\" data-kid=\"1\">\n  <a href=\"#\" class=\"text-2xl italic font-black text-white font-display mix-blend-difference\" data-kid=\"2\">Sử Việt</a>\n  <ul class=\"flex gap-12 font-mono text-[10px] tracking-[0.2em] text-white/70 uppercase mix-blend-difference\" data-kid=\"3\">\n    <li data-kid=\"4\"><a href=\"#chuong-trinh\" class=\"hover:text-[var(--vn-gold)] transition-colors\" data-kid=\"5\">Chương Trình</a></li>\n    <li data-kid=\"6\"><a href=\"#manifesto\" class=\"hover:text-[var(--vn-gold)] transition-colors\" data-kid=\"7\">Sứ Mệnh</a></li>\n    <li data-kid=\"8\"><a href=\"#tinh-nang\" class=\"hover:text-[var(--vn-gold)] transition-colors\" data-kid=\"9\">Tính Năng</a></li>\n    <li data-kid=\"10\"><a href=\"#lien-he\" class=\"hover:text-[var(--vn-gold)] transition-colors\" data-kid=\"11\">Liên Hệ</a></li>\n  </ul>\n</nav>\n\n\n<section class=\"relative w-full h-screen min-h-[700px] overflow-hidden\" data-kid=\"12\">\n  <video src=\"https://kombai-assets.b-cdn.net/generated_assets/23ef1097-47db-4cfb-b45f-423ef4fa11bd/50c02312ca2a4856bac6ba568200e286.mp4\" class=\"hero-video absolute inset-0 object-cover w-full h-full scale-110\" autoplay muted loop playsinline poster=\"https://kombai-assets.b-cdn.net/generated_assets/23ef1097-47db-4cfb-b45f-423ef4fa11bd/50c02312ca2a4856bac6ba568200e286.mp4?auto=compress&cs=tinysrgb&w=1920&q=80\" data-kid=\"13\"></video>\n  \n  <div class=\"absolute inset-0 bg-gradient-to-b from-black/60 via-transparent to-black/80\" data-kid=\"14\"></div>\n\n  <div class=\"absolute bottom-20 left-12 z-10 max-w-6xl\" data-kid=\"15\">\n    <p id=\"hero-eyebrow\" class=\"mb-5 font-mono text-xs tracking-[0.4em] uppercase text-[var(--vn-gold)] opacity-0 translate-y-4\" data-kid=\"16\">\n      Giáo dục 4.0 · Kỷ nguyên số\n    </p>\n    <h1 id=\"hero-title\" class=\"mb-10 italic font-black leading-[0.82] text-white font-display text-7xl md:text-9xl lg:text-[10.5rem] drop-shadow-2xl opacity-0 -translate-x-12\" data-kid=\"17\">\n      Học Lịch Sử <br data-kid=\"18\"> Việt Nam\n    </h1>\n    <div id=\"hero-stats\" class=\"flex items-center gap-8 mb-10 opacity-0 transl